@inherits LayoutComponentBase
@using ToDoAPP.Services
@inject TaskService TaskService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="app-container">
    <div class="sidebar" style="width: 320px;">
        <div class="profile">
            <div class="user-avatar">@(string.IsNullOrEmpty(username) ? "U" : username[0].ToString().ToUpper())</div>
            <h4>@username</h4> 
        </div>
        <nav class="nav flex-column">
            <NavLink class="nav-link" href="/task" ActiveClass="active">
                <span class="oi oi-document"></span> Task
            </NavLink>
            <NavLink class="nav-link" href="/settings" ActiveClass="active">
                <span class="oi oi-cog"></span> Settings
            </NavLink>
        </nav>
        <div class="logout-section">
            <button class="btn btn-logout" @onclick="Logout">Выйти</button>
        </div>
    </div>
    <div class="main-content">
        @Body
    </div>
</div>

<style>
    .app-container {
        display: flex;
        min-height: 100vh;
    }
    .sidebar {
        background-color: #f8f9fa;
        border-right: 1px solid #ddd;
        padding-top: 20px;
        display: flex;
        flex-direction: column;
    }
    .user-avatar {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        background-color: #007bff;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        font-weight: bold;
        margin: 0 auto 10px;
    }
    .profile h4 {
        text-align: center;
        margin: 0;
    }
    .nav-link {
        color: black;
        padding: 10px 20px;
        text-decoration: none;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .nav-link.active {
        background-color: #007bff;
        color: white;
    }
    .main-content {
        flex: 1;
        padding: 20px;
        overflow-x: auto;
    }
    .logout-section {
        margin-top: auto;
        padding: 20px;
        border-top: 1px solid #ddd;
    }
    .btn-logout {
        width: 100%;
        padding: 10px;
        background-color: #dc3545;
        color: white;
        border: none;
        border-radius: 4px;
        cursor: pointer;
    }
    .btn-logout:hover {
        background-color: #c82333;
    }
</style>

@code {
    private string username = "";
    private string? userPhoto = null;

    protected override async Task OnInitializedAsync()
    {
        username = await JS.InvokeAsync<string>("localStorage.getItem", "username") ?? "User";
        userPhoto = await JS.InvokeAsync<string?>("localStorage.getItem", "userPhoto");
    }

    private async void Logout()
    {
        TaskService.Logout();
        await JS.InvokeVoidAsync("localStorage.removeItem", "accessToken");
        await JS.InvokeVoidAsync("localStorage.removeItem", "username");
        await JS.InvokeVoidAsync("eval", "window.location.href = '/login'");
    }
}