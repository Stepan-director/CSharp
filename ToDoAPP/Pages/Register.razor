@page "/register"
@layout EmptyLayout
@using ToDoAPP.Services
@inject TaskService TaskService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="register-container">
    <h2 class="form-title">Регистрация</h2>

    <div class="form-group">
        <label>Никнейм:</label>
        <input @bind="username" class="form-control" placeholder="Придумайте никнейм" />
    </div>
    <div class="form-group">
        <label>Пароль:</label>
        <input @bind="password" type="password" class="form-control" placeholder="Придумайте пароль (6-32 символов)" />
    </div>
    <div class="form-group">
        <label>Подтверждение пароля:</label>
        <input @bind="confirmPassword" type="password" class="form-control" placeholder="Повторите пароль" />
    </div>
    
    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isSuccess ? "alert-success" : "alert-danger")">@message</div>
    }

    <button class="btn btn-primary" @onclick="DoRegister">Зарегистрироваться</button>

    <div class="auth-links">
        <span>Уже есть аккаунт?</span>
        <a href="/login" class="auth-link">Вход</a>
    </div>
</div>

<style>
    .register-container {
        max-width: 400px;
        padding: 40px;
        border-radius: 16px;
        background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
        color: white;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        box-shadow: 0 20px 60px rgba(245, 87, 108, 0.4);
    }
    .form-title {
        text-align: center;
        margin-bottom: 30px;
        font-size: 28px;
        font-weight: 700;
        letter-spacing: 1px;
        text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.2);
    }
    .auth-links {
        text-align: center;
        margin-top: 20px;
        font-size: 14px;
    }
    .auth-link {
        color: #fbbf24;
        text-decoration: none;
        font-weight: 600;
        margin-left: 5px;
        transition: color 0.3s ease;
    }
    .auth-link:hover {
        color: #f59e0b;
        text-decoration: underline;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-group label {
        display: block;
        margin-bottom: 8px;
        font-weight: 600;
        color: #f1f5f9;
        font-size: 14px;
    }
    .form-control {
        width: 100%;
        padding: 12px 16px;
        border: 2px solid rgba(255, 255, 255, 0.3);
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.95);
        font-size: 15px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }
    .form-control:focus {
        outline: none;
        border-color: #fbbf24;
        background: white;
        box-shadow: 0 0 0 3px rgba(251, 191, 36, 0.2);
    }
    .btn-primary {
        width: 100%;
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: #1e3a5f;
        padding: 14px 20px;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: 600;
        font-size: 16px;
        transition: all 0.3s ease;
        margin-top: 15px;
        box-shadow: 0 4px 15px rgba(251, 191, 36, 0.3);
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(251, 191, 36, 0.4);
    }
    .alert-danger {
        color: #fecaca;
        background-color: rgba(220, 38, 38, 0.2);
        border: 1px solid rgba(220, 38, 38, 0.4);
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }
    .alert-success {
        color: #d1fae5;
        background-color: rgba(16, 185, 129, 0.2);
        border: 1px solid rgba(16, 185, 129, 0.4);
        padding: 12px;
        border-radius: 8px;
        margin-bottom: 20px;
        font-size: 14px;
    }
</style>

@code {
    private string username = "";
    private string password = "";
    private string confirmPassword = "";
    private string message = "";
    private bool isSuccess = false;

    private async Task DoRegister()
    {
        message = "";
        
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            message = "Заполните все поля";
            isSuccess = false;
            return;
        }

        if (password != confirmPassword)
        {
            message = "Пароли не совпадают";
            isSuccess = false;
            return;
        }

        if (password.Length < 6 || password.Length > 32)
        {
            message = "Пароль должен быть от 6 до 32 символов";
            isSuccess = false;
            return;
        }

        var success = await TaskService.Register(username, password);
        
        if (success)
        {
            message = "Регистрация успешна! Теперь вы можете войти.";
            isSuccess = true;
            await Task.Delay(2000);
            await JS.InvokeVoidAsync("eval", "window.location.href = '/login'");
        }
        else
        {
            message = "Пользователь с таким никнеймом уже существует";
            isSuccess = false;
        }
    }
}
