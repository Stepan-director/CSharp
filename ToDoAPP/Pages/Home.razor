@page "/task"
@using ToDoAPP.Models
@using ToDoAPP.Services
@inject TaskService TaskService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<h3>Мои задачи</h3>

<div class="calendar-container" style="width: 1128px;">
    <div class="calendar-row">
        <div class="year-selector">
            <label>Год:</label>
            <select @bind="selectedYear" @bind:after="OnYearMonthChanged">
                @for (int y = DateTime.Now.Year - 5; y <= DateTime.Now.Year + 5; y++)
                {
                    <option value="@y">@y</option>
                }
            </select>
        </div>
        <div class="month-selector">
            <label>Месяц:</label>
            <select @bind="selectedMonth" @bind:after="OnYearMonthChanged">
                @for (int m = 1; m <= 12; m++)
                {
                    <option value="@m">@System.Globalization.CultureInfo.CurrentCulture.DateTimeFormat.GetMonthName(m)</option>
                }
            </select>
        </div>
    </div>
    <div class="days-row">
        @foreach (var day in daysInMonth)
        {
            <button class="day-button @(day == selectedDay ? "selected" : "")"
                    @onclick="() => SelectDay(day)">
                @day
            </button>
        }
    </div>
</div>

<div class="action-bar">
    <button class="btn btn-primary" @onclick="OpenAddTaskModal">+ Добавить задачу</button>
    <div class="filters">
        <button class="btn @(currentFilter == "today" ? "btn-info" : "btn-secondary")" 
                @onclick='() => SetFilter("today")'>
            📅 Сегодня
        </button>
        <button class="btn @(currentFilter == "all" ? "btn-info" : "btn-secondary")" 
                @onclick='() => SetFilter("all")'>
            📋 Все задачи
        </button>
    </div>
</div>

<div class="task-table-container">
    <!-- Активные задачи -->
    @if (ActiveTasks.Any())
    {
        <div class="task-section">
            <h4 class="section-title active-title">
                📋 Активные задачи (@ActiveTasks.Count())
            </h4>
            <table class="table table-striped">
                <thead>
                    <tr>
                        <th style="width: 50px;">Выполнено</th>
                        <th>Название</th>
                        <th>Срок</th>
                        <th style="width: 100px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in ActiveTasks)
                    {
                        <tr>
                            <td style="width: 50px;">
                                <input type="checkbox" 
                                       checked="@task.Completed" 
                                       @onchange="() => ToggleCompleted(task)" />
                            </td>
                            <td>@task.Content</td>
                            <td class="@(IsOverdue(task) ? "overdue-date" : "")">
                                @(task.DueDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не указана")
                                @if (IsOverdue(task))
                                {
                                    <span class="overdue-badge">Просрочено!</span>
                                }
                            </td>
                            <td style="white-space: nowrap;">
                                <button class="btn btn-sm btn-warning" @onclick="() => OpenEditTaskModal(task)" style="margin-right: 5px;">✏️</button>
                                <button class="btn btn-sm btn-danger" @onclick="() => DeleteTask(task.Id)">🗑️</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <!-- Выполненные задачи (сворачиваемые) -->
    @if (CompletedTasks.Any())
    {
        <div class="task-section completed-section">
            <div class="completed-header" @onclick="ToggleCompletedSection">
                <h4 class="section-title completed-title" style="cursor: pointer;">
                    @(showCompleted ? "▼" : "▶") ✅ Выполненные задачи (@CompletedTasks.Count())
                </h4>
            </div>
            
            @if (showCompleted)
            {
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th style="width: 50px;">Выполнено</th>
                            <th>Название</th>
                            <th>Срок</th>
                            <th style="width: 100px;">Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in CompletedTasks)
                        {
                            <tr class="completed-row">
                                <td style="width: 50px;">
                                    <input type="checkbox" 
                                           checked="@task.Completed" 
                                           @onchange="() => ToggleCompleted(task)" />
                                </td>
                                <td class="completed-task">@task.Content</td>
                                <td class="completed-task">@(task.DueDate?.ToString("dd.MM.yyyy HH:mm") ?? "Не указана")</td>
                                <td style="white-space: nowrap;">
                                    <button class="btn btn-sm btn-warning" @onclick="() => OpenEditTaskModal(task)" style="margin-right: 5px;">✏️</button>
                                    <button class="btn btn-sm btn-danger" @onclick="() => DeleteTask(task.Id)">🗑️</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    }

    @if (!tasks.Any())
    {
        <div class="empty-state">
            <p>Нет задач</p>
        </div>
    }
</div>

<!-- Модальное окно -->
@if (showModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h4>@(isEditMode ? "Редактировать задачу" : "Новая задача")</h4>
            <div class="form-group">
                <label>Название:</label>
                <input @bind="editTask.Content" class="form-control" />
            </div>
            <div class="form-group">
                <label>Дата выполнения:</label>
                <input type="datetime-local" @bind="editTask.DueDate" class="form-control" />
            </div>
            <div class="form-group">
                <label>Выполнено:</label>
                <input type="checkbox" @bind="editTask.Completed" />
            </div>
            <div class="modal-buttons">
                <button class="btn btn-success" @onclick="SaveTask">Сохранить</button>
                <button class="btn btn-secondary" @onclick="CloseModal">Отмена</button>
            </div>
        </div>
    </div>
}

<style>

    .calendar-container { margin-bottom: 20px; border: 1px solid #ddd; padding: 10px; border-radius: 8px; }
    .calendar-row { display: flex; gap: 20px; margin-bottom: 10px; }
    .year-selector, .month-selector { display: flex; align-items: center; gap: 5px; }
    .days-row { display: flex; flex-wrap: wrap; gap: 5px; }
    .day-button { width: 30px; height: 30px; border: 1px solid #ccc; background: #f8f9fa; border-radius: 4px; cursor: pointer; }
    .day-button.selected { background: #007bff; color: white; border-color: #007bff; }
    .action-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
    .filters { display: flex; gap: 10px; }
    .task-table-container { max-height: 400px; overflow-y: auto; border: 1px solid #ddd; border-radius: 8px; }
    .completed-task { text-decoration: line-through; color: #6c757d; }
    .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); display: flex; justify-content: center; align-items: center; z-index: 1000; }
    .modal-content { background: white; padding: 20px; border-radius: 8px; width: 400px; max-width: 90%; }
    .modal-buttons { display: flex; justify-content: flex-end; gap: 10px; margin-top: 20px; }
    .form-group { margin-bottom: 15px; }
    .form-group label { display: block; margin-bottom: 5px; }
    .form-control { width: 100%; padding: 6px 12px; border: 1px solid #ccc; border-radius: 4px; }

    /* Кнопки */
    .btn-primary, .btn-info, .btn-secondary, .btn-warning {
        background-color: #007bff !important;
        border-color: #007bff !important;
        color: white !important;
    }
    .btn-primary:hover, .btn-info:hover, .btn-secondary:hover, .btn-warning:hover {
        background-color: #0069d9 !important;
        border-color: #0062cc !important;
    }
    .btn-danger {
        background-color: #dc3545 !important;
        border-color: #dc3545 !important;
        color: white !important;
    }
    .btn-danger:hover {
        background-color: #c82333 !important;
        border-color: #bd2130 !important;
    }
/* Кнопки в таблице */
    .btn-sm {
        padding: 4px 8px;
        font-size: 12px;
        margin: 0 2px;
        display: inline-flex;
        align-items: center;
        gap: 4px;
    }

    /* Убедимся, что ячейка не переносится */
    td:last-child {
        white-space: nowrap;
    }

    /* Секции задач */
    .task-section { margin-bottom: 30px; }
    .section-title { font-size: 18px; font-weight: 600; margin: 20px 0 15px 0; padding-bottom: 8px; border-bottom: 2px solid; }
    .active-title { color: #1e3a8a; border-bottom-color: #1e3a8a; }
    .completed-title { color: #6c757d; border-bottom-color: #6c757d; }
    .completed-section { opacity: 0.8; }
    .completed-row { background-color: #f8f9fa; }
    .overdue-date { color: #dc2626; font-weight: 500; }
    .overdue-badge { background-color: #dc2626; color: white; font-size: 11px; padding: 2px 6px; border-radius: 4px; margin-left: 8px; }
    .empty-state { text-align: center; padding: 40px; color: #6c757d; font-size: 16px; }
</style>

@code {
    private List<TaskItem> ActiveTasks => tasks.Where(t => !t.Completed).ToList();
    private List<TaskItem> CompletedTasks => tasks.Where(t => t.Completed).ToList();

    private int selectedYear = DateTime.Now.Year;
    private int selectedMonth = DateTime.Now.Month;
    private int selectedDay = DateTime.Now.Day;
    private List<int> daysInMonth = new();

    private List<TaskItem> tasks = new();
    private string currentFilter = "today"; // "today" или "all"

    private bool showModal = false;
    private bool isEditMode = false;
    private TaskItem editTask = new();

    private bool showCompleted = false; // false - скрыто, true - показано

    // Метод для переключения видимости
    private void ToggleCompletedSection()
    {
        showCompleted = !showCompleted;
    }


    // Проверка просрочки (только если дата строго раньше сегодняшнего дня)
    private bool IsOverdue(TaskItem task)
    {
        return !task.Completed && task.DueDate.HasValue && task.DueDate.Value.Date < DateTime.Today;
    }

    protected override async Task OnInitializedAsync()
    {
        // Пытаемся восстановить токен из localStorage
        if (!TaskService.IsAuthenticated)
        {
            var token = await JS.InvokeAsync<string>("localStorage.getItem", "accessToken");
            if (!string.IsNullOrEmpty(token))
            {
                TaskService.SetAccessToken(token);
            }
            else
            {
                await JS.InvokeVoidAsync("eval", "window.location.href = '/login'");
                return;
            }
        }
        
        UpdateDaysInMonth();
    }

    private async Task OnYearMonthChanged()
    {
        UpdateDaysInMonth();
        // Если выбран не режим "Все задачи", то при смене месяца/года загружаем задачи на выбранную дату
        if (currentFilter != "all")
        {
            currentFilter = "today";
            await LoadTasks();
        }
        else
        {
            // Если в режиме "Все задачи", остаёмся в нём
            await LoadTasks();
        }
    }

    private async Task SelectDay(int day)
    {
        selectedDay = day;
        if (currentFilter != "all")
        {
            currentFilter = "today";
            await LoadTasks();
        }
        else
        {
            await LoadTasks();
        }
    }

    private async Task SetFilter(string filter)
    {
        currentFilter = filter;
        await LoadTasks();
    }

    private async Task LoadTasks()
    {
        if (currentFilter == "all")
        {
            tasks = await TaskService.GetAllTasksAsync();
        }
        else // "today"
        {
            var selectedDate = new DateTime(selectedYear, selectedMonth, selectedDay);
            tasks = await TaskService.GetTasksByDateAsync(selectedDate);
        }
    }

    private void UpdateDaysInMonth()
    {
        int days = DateTime.DaysInMonth(selectedYear, selectedMonth);
        daysInMonth = Enumerable.Range(1, days).ToList();
        if (selectedDay > days) selectedDay = days;
    }

    private void OpenAddTaskModal()
    {
        isEditMode = false;
        editTask = new TaskItem
        {
            DueDate = new DateTime(selectedYear, selectedMonth, selectedDay, 12, 0, 0)
        };
        showModal = true;
    }

    private void OpenEditTaskModal(TaskItem task)
    {
        isEditMode = true;
        editTask = new TaskItem
        {
            Id = task.Id,
            Content = task.Content,
            Completed = task.Completed,
            DueDate = task.DueDate
        };
        showModal = true;
    }

    private async Task SaveTask()
    {
        if (isEditMode)
        {
            await TaskService.UpdateTaskAsync(editTask.Id, editTask);
        }
        else
        {
            await TaskService.AddTaskAsync(editTask);
        }
        CloseModal();
        await LoadTasks();
    }

    private void CloseModal()
    {
        showModal = false;
        editTask = new TaskItem();
    }

    private async Task ToggleCompleted(TaskItem task)
    {
        task.Completed = !task.Completed;
        await TaskService.UpdateTaskAsync(task.Id, task);
        await LoadTasks();
    }

    private async Task DeleteTask(Guid id)
    {
        await TaskService.DeleteTaskAsync(id);
        await LoadTasks();
    }
}